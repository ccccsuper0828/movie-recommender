# CineMatch Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Application Settings
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Application name
APP_NAME=CineMatch

# Debug mode (set to false in production)
DEBUG=true

# =============================================================================
# Server Configuration
# =============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Server
STREAMLIT_PORT=8501

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# =============================================================================
# Data Paths
# =============================================================================

# Base data directory
DATA_PATH=./data

# Raw data files
RAW_DATA_PATH=./data/raw

# Processed data files
PROCESSED_DATA_PATH=./data/processed

# Cache directory for similarity matrices
CACHE_DIR=./data/cache

# User data storage
USER_DATA_PATH=./data/users

# Metrics storage
METRICS_PATH=./data/metrics

# =============================================================================
# Model Configuration
# =============================================================================

# Default recommendation count
DEFAULT_TOP_N=10

# Hybrid recommender weights
CONTENT_WEIGHT=0.3
METADATA_WEIGHT=0.4
CF_WEIGHT=0.3

# TF-IDF parameters
TFIDF_MAX_FEATURES=5000
TFIDF_NGRAM_RANGE=1,2

# Count vectorizer for metadata
COUNT_VECTORIZER_MAX_FEATURES=10000

# Collaborative filtering
CF_N_USERS=1000
SVD_N_FACTORS=50

# =============================================================================
# Cache Configuration
# =============================================================================

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# Enable caching
ENABLE_CACHING=true

# Redis URL (if using Redis for distributed caching)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=text

# =============================================================================
# Security (for production)
# =============================================================================

# Secret key for JWT (generate a secure random key)
# SECRET_KEY=your-secret-key-here

# =============================================================================
# Feature Flags
# =============================================================================

# Enable SHAP explanations
ENABLE_SHAP=true

# Enable user management features
ENABLE_USER_MANAGEMENT=true

# Enable analytics tracking
ENABLE_ANALYTICS=true
